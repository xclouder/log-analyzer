{
  "name": "log-analyzer-new",
  "version": "1.1.18",
  "description": "A powerful log analysis tool - TypeScript rewrite",
  "main": "dist/main/main/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "electron .",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:portable": "npm run build && electron-builder --win portable",
    "build:nsis": "npm run build && electron-builder --win nsis",
    "build:mac": "npm run build && electron-builder --mac zip",
    "dist": "npm run build && electron-builder --win nsis --publish always",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xclouder/log-analyzer.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "electron-updater": "^6.1.4",
    "iconv-lite": "^0.6.3",
    "chardet": "^2.0.0",
    "log4js": "^6.9.1",
    "monaco-editor": "^0.40.0",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/electron": "^1.6.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@types/yauzl": "^2.10.3",
    "electron": "^25.3.1",
    "electron-builder": "^24.6.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "org.xclouder.loganalyzer",
    "productName": "LogAnalyzer",
    "publish": [
      {
        "provider": "github",
        "owner": "xclouder",
        "repo": "log-analyzer"
      }
    ],
    "directories": {
      "output": "dist-build"
    },
    "extraResources": [
      {
        "from": "node_modules/monaco-editor/min",
        "to": "monaco-editor/min",
        "filter": ["**/*"]
      },
      {
        "from": "src/plugins",
        "to": "plugins",
        "filter": ["**/*"]
      },
      {
        "from": "node_modules/adm-zip",
        "to": "node_modules/adm-zip",
        "filter": ["**/*"]
      },
      {
        "from": "node_modules/yauzl",
        "to": "node_modules/yauzl",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "icon": "assets/icon.ico",
      "target": ["dmg", "zip"]
    },
    "portable": {
      "artifactName": "LogAnalyzer.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
